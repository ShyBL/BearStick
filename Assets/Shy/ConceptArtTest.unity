MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1748626017}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: afdfc36b4a2263a48b1e25db1b95fc61, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogue: {fileID: 1354427191}
  talkingSprite: {fileID: 21300000, guid: d50a10c6ce1dd634fa5c783424413c20, type: 3}
  dialogueLines:
  - "\u201CLet\u2019s start with the basics. Use the Left and Right arrow keys to
    move around, and Spacebar to jump. A lot of folks like to live higher up\u2013
    more people means more trash.\u201D  "
  - "\u201CDon\u2019t forget to use those claws! You can slide down or even stick
    to walls, depending on what the wall is made out of. You can even jump off of
    walls using Spacebar!\u201D "
  - "\u201CJust one other thing. Sometimes, there\u2019s just no other way around
    something. You can push objects around.\u201D "
  - "\u201CMost of the locks have rusted off the dumpsters by now\u2013you can use
    the E key to open them up.\u201D "
  - "\u201CBe careful, though. You can only carry so much at once, so be sure to
    drop off what ya got at the cache to clear up some space.\u201D"
  startLevel: 0
  startLevelDOONCE: 1
  jumping: 0
  jumpingDOONCE: 1
  pushing: 0
  pushingDOONCE: 1
  opening: 0
  openingDOONCE: 1
  carrying: 0
  carryingDOONCE: 1
